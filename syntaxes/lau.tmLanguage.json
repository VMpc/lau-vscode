{
  "name": "LAU",
  "scopeName": "source.lau",
  "fileTypes": ["lau", "laum"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#control" },
    { "include": "#builtins" },
    { "include": "#enums" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.lau",
          "begin": "--\\[\\[",
          "end": "\\]\\]"
        },
        {
          "name": "comment.line.double-dash.lau",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lau",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.lau",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.lau",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.lau",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.lau",
          "match": "\\b(varol|func|req)\\b"
        },
        {
          "name": "keyword.control.lau",
          "match": "\\b(if|then|else|elseif|end|do|while|for|in|return|break)\\b"
        },
        {
          "name": "keyword.operator.logical.lau",
          "match": "\\b(AND|OR|NOT)\\b"
        },
        {
          "name": "keyword.other.lau",
          "match": "\\b(local|true|false|null|nil)\\b"
        }
      ]
    },
    "control": {
      "patterns": [
        {
          "name": "keyword.control.event.lau",
          "match": "\\b(connect)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.drone.lau",
          "match": "\\b(drone)\\.(move|doFlip|getPosition|getPositionX|getPositionZ|plant|useItem|crop|Harvest|canCrop|canHarvest|getPlant|getPlantPercent|getPlantWeight|getPlantHasFruit|getFruit|getFruitPercent)\\b"
        },
        {
          "name": "support.function.droneV2.lau",
          "match": "\\b(droneV2)\\.(doBig|doSpin|doWobble|goto|isLocked|lock|unlock)\\b"
        },
        {
          "name": "support.function.player.lau",
          "match": "\\b(player)\\.(getFruitCount|getInventorysize|getInventory|getItem|geTileNumber|calculateFinalScrap|scrap|alert|sent|chatted|input|getcurrentTile|getCurrentTile|camera|cameraMode)\\b"
        },
        {
          "name": "support.function.playerV2.lau",
          "match": "\\b(playerV2)\\.(boughtGear|boughtSeed|clicked|getGift)\\b"
        },
        {
          "name": "support.function.market.lau",
          "match": "\\b(market)\\.(getSeedStockTime|getSeedStock|getSeedPrice|buySeed|getGearStockTime|getGearStock|getGearPrice|buyGear|whatValue|sellItem|sellAllItem|changedSeedStock|changedGearStock)\\b"
        },
        {
          "name": "support.function.http.lau",
          "match": "\\b(player)\\.(get|post|jsonEncode|jsonDecode)\\b"
        },
        {
          "name": "support.function.list.lau",
          "match": "\\b(player)\\.(insert|remove|clear|check|find)\\b"
        },
        {
          "name": "support.function.game.lau",
          "match": "\\b(game)\\.(weather|weatherDuration|changedWeather|rejoin)\\b"
        },
        {
          "name": "support.function.task.lau",
          "match": "\\b(task)\\.(wait)\\b"
        },
        {
          "name": "support.function.math.lau",
          "match": "\\b(math)\\.(random|round|abs|pi)\\b"
        },
        {
          "name": "support.function.string.lau",
          "match": "\\b(string)\\.(upper|lower|len|sub|find)\\b"
        },
        {
          "name": "support.function.global.lau",
          "match": "\\b(print|printn|req|type|pcall|error|tonumber|tostring|clear|inpairs)\\b"
        }
      ]
    },
    "enums": {
      "patterns": [
        {
          "name": "support.class.enum.lau",
          "match": "\\b(Enum)\\.(Direction|Seed|Gear|Camera|CameraMode|Keycode|ClickType)\\b"
        },
        {
          "name": "support.constant.enum.value.lau",
          "match": "\\b(Enum)\\.(Direction|Seed|Gear|Camera|CameraMode|Keycode|ClickType)\\.(\\w+)\\b",
          "captures": {
            "3": { "name": "variable.other.enummember.lau" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.lau",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.lau",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.lau",
          "match": "\\b(null|nil)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.lau",
          "match": "(==|~=|!=|<=|>=|<|>|\\+|-|\\*|\\/|%|\\^|#|\\.\\.)"
        },
        {
          "name": "keyword.operator.assignment.lau",
          "match": "(?<![=!<>])=(?!=)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.lau",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
